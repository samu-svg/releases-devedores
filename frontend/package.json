{
  "name": "sistema-cobranca",
  "productName": "Sistema de Cobranca",
  "version": "1.1.0",
  "description": "Sistema de gerenciamento de devedores com cálculo de juros",
  "main": "out/main/main.js",
  "author": "Sistema Cobrança",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "preview": "electron-vite preview",
    "build:installer": "npm run build && node scripts/prepare-backend.js && electron-builder --win",
    "dist": "npm run build:installer"
  },
  "build": {
    "appId": "com.cobranca.sistema",
    "productName": "Sistema de Cobrança",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "backend-bundle/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistema de Cobrança"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.1"
  }
}
